{
  "name": "@maptoolkit/leaflet-logo",
  "version": "0.1.0",
  "description": "Maptoolkit logo control for Leaflet.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "prebuild": "node ../../scripts/embed-logo.mjs src/logo.generated.ts",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "leaflet": ">=1.7.0 <3.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "leaflet": "^1.9.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
