{
  "name": "@maptoolkit/maplibre-gl-logo",
  "version": "0.1.0",
  "description": "Maptoolkit logo control for MapLibre GL JS.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "prebuild": "node ../../scripts/embed-logo.mjs src/logo.generated.ts",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "maplibre-gl": ">=2.0.0 <6.0.0"
  },
  "devDependencies": {
    "maplibre-gl": "^4.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
