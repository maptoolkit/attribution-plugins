{
  "name": "maptoolkit-attribution",
  "private": true,
  "version": "0.0.0",
  "description": "Maptoolkit attribution/logo plugins for various map libraries.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:logo": "node scripts/embed-logo.mjs packages/maplibre-gl/src/logo.generated.ts && node scripts/embed-logo.mjs packages/leaflet/src/logo.generated.ts",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "license": "MIT"
}
